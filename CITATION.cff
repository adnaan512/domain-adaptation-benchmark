    given-names: "Adnan"
    affiliation: "NUST Pakistan"

references:
  - type: article
    title: "Benchmarking Neural Network Robustness to Common Corruptions and Perturbations"
    authors:
      - family-names: "Hendrycks"
        given-names: "Dan"
      - family-names: "Dietterich"
        given-names: "Thomas"
    year: 2019
    journal: "International Conference on Learning Representations (ICLR)"
    url: "https://arxiv.org/abs/1903.12261"
    notes: "Introduces CIFAR-10-C, the 15-corruption benchmark dataset used in this project."

  - type: article
    title: "Tent: Fully Test-Time Adaptation by Entropy Minimization"
    authors:
      - family-names: "Wang"
        given-names: "Dequan"
      - family-names: "Shelhamer"
        given-names: "Evan"
      - family-names: "Liu"
