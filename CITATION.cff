        given-names: "Bruno"
      - family-names: "Darrell"
        given-names: "Trevor"
    year: 2021
    journal: "International Conference on Learning Representations (ICLR)"
    url: "https://arxiv.org/abs/2006.10726"
    notes: "Proposes TENT: minimising prediction entropy to update BN affine parameters at test time."

  - type: article
    title: "Improving Robustness Against Common Corruptions by Covariate Shift Adaptation"
    authors:
      - family-names: "Schneider"
        given-names: "Steffen"
      - family-names: "Rusak"
